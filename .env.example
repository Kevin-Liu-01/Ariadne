# ---------------------------------------------------------------------------
# Ariadne environment
# Copy to .env.local and fill in. Never commit real secrets.
# ---------------------------------------------------------------------------

# Fixed event identifier, threaded through every route / webhook / projection event.
ARIADNE_EVENT_ID=nytw-runwaytime

# Public origin where AgentPhone can reach this server (a tunnel during dev,
# e.g. https://xyz.trycloudflare.com). On Vercel this is derived from VERCEL_URL.
# Also hosts /ariadne.vcf for the saveable contact card AgentPhone attaches on first text.
ARIADNE_PUBLIC_BASE_URL=http://localhost:3939

# Postgres connection string (Supabase pooler). Use the Transaction pooler
# (port 6543) for serverless. Settings -> Database -> Connection string.
# postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=postgresql://postgres.<ref>:<password>@aws-1-us-east-1.pooler.supabase.com:6543/postgres

# Bearer token guarding /api/operator/* (bartender + run-of-show console).
ARIADNE_OPERATOR_TOKEN=change-me-operator

# Bearer token guarding /api/agent/* and the MCP server (what you strap onto
# a running agent like Claude Code or OpenClaw).
ARIADNE_AGENT_TOKEN=change-me-agent

# Set to "1" to never place real outbound AgentPhone sends (dry-run replies).
ARIADNE_DISABLE_OUTBOUND=0

# Bearer secret for /api/cron/sweep (Vercel Cron sends Authorization: Bearer <this>).
# Generate: openssl rand -hex 32
CRON_SECRET=

# Conversational brain model (Dedalus gateway, `provider/model`). `pnpm dlx` GET
# /v1/models to see the catalog. gpt-5-mini balances speed + tool-calling.
ARIADNE_MODEL=openai/gpt-5-mini
ARIADNE_AGENT_MAX_STEPS=5

# ---------------------------------------------------------------------------
# Dedalus gateway (https://docs.dedaluslabs.ai) — the conversational brain
# ---------------------------------------------------------------------------
DEDALUS_API_KEY=dsk_live_xxx
DEDALUS_BASE_URL=https://api.dedaluslabs.ai/v1

# ---------------------------------------------------------------------------
# AgentPhone (https://docs.agentphone.ai)
# ---------------------------------------------------------------------------
AGENTPHONE_API_KEY=sk_live_xxx
AGENTPHONE_BASE_URL=https://api.agentphone.ai/v1

# Filled in by `pnpm provision` (creates the agent + number + per-agent webhook).
AGENTPHONE_AGENT_ID=
AGENTPHONE_NUMBER_ID=
AGENTPHONE_PHONE_NUMBER=
AGENTPHONE_WEBHOOK_SECRET=
