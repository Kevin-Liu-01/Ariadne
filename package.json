{
  "name": "ariadne",
  "version": "0.1.0",
  "private": true,
  "description": "Ariadne - your personal agent for the night. A phone-first event backbone you strap onto a running agent.",
  "scripts": {
    "dev": "next dev -p 3939",
    "build": "next build",
    "start": "next start -p ${PORT:-3939}",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate:icons": "tsx scripts/generate-mark-icons.ts",
    "generate:sdf": "tsx scripts/generate-logo-sdf.ts",
    "seed": "tsx scripts/seed-demo.ts",
    "provision": "tsx scripts/provision.ts",
    "smoke": "tsx scripts/smoke.ts",
    "smoke:agent": "tsx scripts/smoke-agent.ts",
    "simulate": "tsx scripts/simulate-inbound.ts",
    "migrate": "tsx scripts/migrate.ts",
    "reset-event": "tsx scripts/reset-event.ts",
    "tunnel": "cloudflared tunnel --url http://localhost:3939",
    "mcp": "tsx src/mcp/server.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "obscenity": "^0.4.6",
    "pg": "^8.21.0",
    "pixi.js": "^8.19.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shaders": "^2.5.129",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.6",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
