{
  "name": "ariadne",
  "version": "0.1.0",
  "private": true,
  "description": "Ariadne - the thread through the labyrinth. A phone-first event backbone you strap onto a running agent.",
  "scripts": {
    "dev": "next dev -p 3939",
    "build": "next build",
    "start": "next start -p 3939",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "tsx scripts/seed-demo.ts",
    "provision": "tsx scripts/provision.ts",
    "smoke": "tsx scripts/smoke.ts",
    "simulate": "tsx scripts/simulate-inbound.ts",
    "tunnel": "cloudflared tunnel --url http://localhost:3939",
    "mcp": "tsx src/mcp/server.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.10.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
